FYERS_APP_ID=your_app_id_here
FYERS_APP_SECRET=your_app_secret_here
FYERS_ACCESS_TOKEN=your_access_token_here
FYERS_CLIENT_ID=your_client_id_here

# Risk Management Settings
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
POSITION_SIZE_PERCENT=0.1

# Trading Settings
EMA_PERIOD_SHORT=9
EMA_PERIOD_LONG=21
STOP_LOSS_PERCENT=0.015
TARGET_PROFIT_PERCENT=0.03

# Daily Profit Target Settings
DAILY_PROFIT_TARGET=1000
DAILY_STOP_LOSS=500
AUTO_TRADING_ENABLED=true
FOCUS_SYMBOL=NIFTY

# High-Probability Trading Settings
MIN_WIN_RATE=0.85
STRONG_SIGNAL_THRESHOLD=80
